# Frontend env vars
# Base URL of the FastAPI backend used by the web app
# Example for local docker-compose (backend on port 8000):
VITE_RUNNER_URL=http://localhost:8080

# API Keys - Set these with your actual API keys
SERPAPI_API_KEY=paste_your_serpapi_key_here

# Get your OpenAI key from: https://platform.openai.com/api-keys
# Should start with 'sk-'
OPENAI_API_KEY=sk-paste_your_openai_key_here
